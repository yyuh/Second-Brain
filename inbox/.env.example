# Second Brain 输入站配置
# 复制为 .env 并填入实际值

# 飞书 Bot 凭证（在飞书开发者后台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_VERIFY_TOKEN=xxxxxxxxxxxx

# ngrok 认证令牌（可选，启用了会自动开隧道）
# 从 https://dashboard.ngrok.com 获取
NGROK_AUTOTOKEN=
